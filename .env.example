# URL de conexão com o banco de dados PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
# Para rodar localmente (sem Docker):
DATABASE_URL=postgresql://postgres:senha@localhost:5432/taskmanager
# Para rodar com Docker (use o nome do serviço "db" como host):
# DATABASE_URL=postgresql://postgres:postgres@db:5432/taskmanager

# Chave secreta para assinar os tokens JWT
# Gere uma chave forte: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-forte
